# Neon PostgreSQL (https://neon.tech)
# Use the *pooled* connection string from Neon dashboard.
# On Vercel: Project → Settings → Environment Variables → add for Production + Preview
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Admin panel (required on Vercel too)
ADMIN_PASSWORD=your-secure-password
ADMIN_SESSION_SECRET=your-long-random-secret

# Reserveringen in /admin komen alleen uit de database (website /api/reservations + handmatig in admin).
# Geen demo-reserveringen meer bij db:seed. Oude demo's verwijderen: pnpm db:clear-demo-reservations
