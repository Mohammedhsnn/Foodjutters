# Neon PostgreSQL (https://neon.tech)
# Use the *pooled* connection string from Neon dashboard.
# On Vercel: Project → Settings → Environment Variables → add for Production + Preview
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Admin panel (required on Vercel too)
ADMIN_PASSWORD=your-secure-password
ADMIN_SESSION_SECRET=your-long-random-secret

# Reserveringen in /admin komen alleen uit de database (website /api/reservations + handmatig in admin).
# Geen demo-reserveringen meer bij db:seed. Oude demo's verwijderen: pnpm db:clear-demo-reservations

# Formspree (contact + groepsreservering op /contact)
# 1. Maak gratis account op https://formspree.io
# 2. Maak twee formulieren (Contact + Groepsreservering)
# 3. Kopieer elk Form ID (de code na /f/ in de endpoint-URL, bijv. xyzabcde)
# 4. Zet hier en op Vercel (Production + Preview):
FORMSPREE_CONTACT_FORM_ID=xkolrwoa
FORMSPREE_GROUP_FORM_ID=xqevqzqb

# Optioneel: publieke site-URL voor SEO (canonical / Open Graph)
# NEXT_PUBLIC_SITE_URL=https://www.foodjutters.nl
